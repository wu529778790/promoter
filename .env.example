# =============================================
# GitHub Promoter 环境变量配置
# =============================================
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env

# GitHub Personal Access Token（需要 repo 权限）
# 如果使用 GitHub OAuth 登录，此值会自动填入
GITHUB_TOKEN=your_github_token_here

# GitHub OAuth（可选，用于 Web UI 登录）
# 在 https://github.com/settings/applications/new 创建
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3456/auth/github/callback

# SMTP 发件邮箱配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password_or_app_code
SMTP_DAILY_LIMIT=200

# 产品信息（用于邮件模板）
PRODUCT_NAME=My Awesome Project
PRODUCT_DESC=A great open source project
GITHUB_REPO=https://github.com/your-username/your-project

# 调试
DRY_RUN=false
LOG_LEVEL=info
