{
  "name": "github-promoter",
  "version": "1.0.0",
  "description": "GitHub 用户邮箱采集 + 推广工具",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "ui": "tsx src/tui.ts",
    "web": "tsx src/server.ts",
    "collect": "tsx src/index.ts collect",
    "preview": "tsx src/index.ts preview",
    "send": "tsx src/index.ts send",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean:logs": "rm -rf logs/"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "inquirer": "^14.0.2",
    "nodemailer": "^6.9.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  }
}
